# TaxFit runs with ZERO configuration — these are all OPTIONAL.
# The assistant uses a deterministic rule-based engine by default.
#
# Set ANTHROPIC_API_KEY to route the assistant's free-text answers through a
# real LLM instead of the simulated engine. The key is used server-side only
# (in app/api/assistant/route.ts) and is never exposed to the browser. Safety
# checks run before any model call, and any API error falls back to the
# simulated engine.

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
